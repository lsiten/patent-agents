# ==================== 专利申请多智能体系统 - 环境配置 ====================

# -------------------- 服务配置 --------------------
HOST=0.0.0.0
PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# -------------------- LLM API 配置 --------------------
# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4-turbo-preview

# Anthropic Claude (可选)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# -------------------- 专利数据库 API 配置 --------------------
# USPTO (美国专利商标局)
USPTO_API_KEY=your_uspto_api_key_here
USPTO_API_URL=https://developer.uspto.gov/ibd-api/v1

# EPO (欧洲专利局) - Open Patent Services
EPO_CONSUMER_KEY=your_epo_consumer_key
EPO_CONSUMER_SECRET=your_epo_consumer_secret

# 中国专利数据库 - CNIPA/PSI
# CNIPA_API_TOKEN=your_cnipa_token

# -------------------- 数据源配置 --------------------
# Google Patents - 浏览器检索 (需要Playwright)
ENABLE_GOOGLE_PATENTS=true

# arXiv 论文检索
ENABLE_ARXIV=true

# -------------------- 知识库配置 --------------------
KNOWLEDGE_BASE_PATH=./finalized_patents
ENABLE_VECTOR_SEARCH=false

# -------------------- 工作流配置 --------------------
# 最大迭代次数（审查-修改循环）
MAX_ITERATIONS=3

# 启用哪些Agent
ENABLE_REQUIREMENT_ANALYST=true
ENABLE_RETRIEVAL_ANALYST=true
ENABLE_PATENT_WRITER=true
ENABLE_QUALITY_REVIEWER=true

# -------------------- 导出配置 --------------------
# 专利文件导出目录
EXPORT_PATH=./exports

# 导出格式支持: pdf, docx, json, md
EXPORT_FORMATS=json,md

# -------------------- 安全配置 --------------------
# API密钥认证 (生产环境必填)
API_SECRET_KEY=your_secure_api_secret_key_here

# CORS 允许的域名
CORS_ALLOWED_ORIGINS=*

# JWT配置
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# -------------------- 数据库配置 (生产环境) --------------------
# SQLite (开发环境默认)
DATABASE_URL=sqlite+aiosqlite:///./patent_agents.db

# PostgreSQL (生产环境推荐)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/patent_agents

# Redis (任务队列)
# REDIS_URL=redis://localhost:6379/0
