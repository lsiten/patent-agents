# ============================================================
# 产线环境专属配置（完整独立，不依赖 .env 中的值）
# 当 ENVIRONMENT=production 时加载，覆盖 .env / 系统环境变量
# 前端端口: 10001  |  后端端口: 10002
# 启动方式: ENVIRONMENT=production python main.py
# ============================================================
# LLM / 安全密钥由部署环境变量注入（注释行仅为占位说明）
# ============================================================

# ── 服务配置 ──
ENVIRONMENT=production
HOST=0.0.0.0
PORT=10002
DEBUG=false
LOG_LEVEL=INFO

# ── 专利数据库 API 配置 ──
USPTO_API_URL=https://developer.uspto.gov/ibd-api/v1
# USPTO_API_KEY=             （由部署环境变量注入）
# EPO_CONSUMER_KEY=          （由部署环境变量注入）
# EPO_CONSUMER_SECRET=       （由部署环境变量注入）

# ── 数据源配置 ──
ENABLE_GOOGLE_PATENTS=true
ENABLE_ARXIV=true

# ── 知识库配置 ──
KNOWLEDGE_BASE_PATH=./prod_finalized_patents
ENABLE_VECTOR_SEARCH=false

# ── 工作流配置 ──
MAX_ITERATIONS=3
ENABLE_REQUIREMENT_ANALYST=true
ENABLE_RETRIEVAL_ANALYST=true
ENABLE_PATENT_WRITER=true
ENABLE_QUALITY_REVIEWER=true

# ── 导出配置 ──
EXPORT_PATH=./prod_exports
EXPORT_FORMATS=["json","md"]
FINALIZED_PATENTS_DOCX_PATH=./prod_定稿文件

# ── 安全配置（由部署环境变量注入，否则启动验证会拒绝）──
API_SECRET_KEY=prod-api-secret-key-change-in-deploy
JWT_SECRET_KEY=prod-jwt-secret-key-change-in-deploy
CORS_ALLOWED_ORIGINS=["*"]
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── 数据库配置 ──
DATABASE_URL=sqlite+aiosqlite:///./prod_patent_agents.db

# ── LLM 配置（由部署环境变量注入）──
# LLM_ACTIVE_PROVIDER=openai
# LLM_OPENAI_API_KEY=
# LLM_OPENAI_BASE_URL=
# LLM_OPENAI_MODEL=
LLM_OPENAI_BASE_URL='http://localhost:8080/v1'
LLM_OPENAI_API_KEY='sk-fcc150de6d8fed3ee40acd720ba3d823d96414ab527795b757fbb35a6c883a8d'
LLM_OPENAI_MODEL='ark-code-latest'
